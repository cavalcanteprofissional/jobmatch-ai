# JobMatch AI — Configuração de Ambiente

# ─── Credenciais Kaggle ───────────────────────────────────────
# Necessárias para baixar datasets como LinkedIn Job Postings.
# Obtenha sua API Key em: https://www.kaggle.com/settings
KAGGLE_USERNAME=seu_usuario_kaggle
KAGGLE_KEY=sua_chave_api_kaggle

# ─── API ──────────────────────────────────────────────────────
# URL da API REST FastAPI (usada pelo Streamlit em modo API)
API_URL=http://localhost:8000

# Forçar Streamlit a usar modo direto (sem API)
# Valores: true (padrão) | false
STREAMLIT_USE_API=true

# Porta do servidor FastAPI
# Útil se a porta 8000 estiver ocupada
# FASTAPI_PORT=8000

# ─── Logging ──────────────────────────────────────────────────
# Nível de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
